# ── CasePilot environment ──────────────────────────────────────────────────
# Copy to .env.local and fill in. Missing vars fail loudly at first use.

# App
APP_URL=http://localhost:3000

# Postgres (Neon) — pgvector enabled
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=casepilot

# Upstash — QStash (durable stage queue) + Redis (state/locks).
# Leave QSTASH_TOKEN unset in local dev to run the pipeline inline (no queue needed).
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Anthropic (extraction / summary / benchmark / score / suggest / compare / OCR)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — OPTIONAL. Enables clause embeddings (pgvector) for cross-contract alignment.
# Leave unset to disable embeddings; compare falls back to clause-type matching.
OPENAI_API_KEY=
